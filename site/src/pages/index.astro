---
import { existsSync, readdirSync, statSync } from 'node:fs';
import { join } from 'node:path';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';

// "Qutie System One v06.stl" -> "Qutie System One", "Qutie Two - 01.jpeg" -> "Qutie Two",
// "Qutie One and Two - hero.jpeg" -> "Qutie One and Two" ("hero" marks the main picture)
const prettify = (filename: string) =>
  filename
    .replace(/\.[^.]+$/, '')
    .replace(/[-_]+/g, ' ')
    .replace(/\bhero\b/gi, '')
    .replace(/\s+v?\d+$/i, '')
    .replace(/\s+/g, ' ')
    .trim();

// Realistic materials for the 3D previews, matched by model name.
const looks: { match: RegExp; color: string; metalness: number; roughness: number; rotate: number }[] = [
  // System One — black enclosure; starts 180° around so the open front faces the viewer
  { match: /one/i, color: '#26272d', metalness: 0.15, roughness: 0.45, rotate: 180 },
  { match: /two/i, color: '#c7ccd6', metalness: 0.45, roughness: 0.35, rotate: 0 }, // System Two — silver cryostat
];
const lookFor = (name: string) =>
  looks.find((l) => l.match.test(name)) ?? { color: '#2fa9cc', metalness: 0.05, roughness: 0.55, rotate: 0 };

// 3D models — synced from /stl by scripts/sync-assets.mjs. Drop an .stl into the
// repo's stl/ folder and it shows up here on the showroom stage.
const modelsDir = join(process.cwd(), 'public', 'models');
const models = existsSync(modelsDir)
  ? readdirSync(modelsDir)
      .filter((f) => f.toLowerCase().endsWith('.stl'))
      .sort()
      .map((file) => {
        const bytes = statSync(join(modelsDir, file)).size;
        const size =
          bytes >= 1048576 ? `${(bytes / 1048576).toFixed(1)} MB` : `${Math.max(1, Math.round(bytes / 1024))} KB`;
        const name = prettify(file);
        return { url: `/models/${encodeURIComponent(file)}`, name, size, look: lookFor(name) };
      })
  : [];
const firstModel = models[0];

// Gallery — synced from /images by scripts/sync-assets.mjs.
const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/gallery/*.{jpg,jpeg,png,webp,gif,avif}',
  { eager: true }
);
const gallery = Object.entries(galleryModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod]) => ({
    file: path.split('/').pop() ?? '',
    src: mod.default,
    caption: prettify(path.split('/').pop() ?? ''),
  }));
// An image with "hero" in its filename becomes the lead picture; falls back to the first one.
const heroPhoto = gallery.find((g) => /hero/i.test(g.file)) ?? gallery[0];

const why = [
  {
    icon: '🖨️',
    title: 'One piece, zero fuss',
    text: 'Designed to print in a single piece on any home FDM printer. No supports to tear off, no parts to glue, no screws to lose, no electronics to wire.',
  },
  {
    icon: '🎁',
    title: 'Born to be given away',
    text: 'Pennies in filament, a few hours on the printer, impossible not to smile at. The perfect conference give-away, workshop souvenir, and desk companion.',
  },
  {
    icon: '💬',
    title: 'A conversation starter',
    text: '“What’s that?” — “A quantum computer.” Works on desks, in classrooms, at meetups. The physics conversation starts itself.',
  },
];

const steps = [
  {
    n: '1',
    icon: '⬇️',
    title: 'Download',
    text: 'Grab an STL from the stage above — free and open source, like everything in the family.',
  },
  {
    n: '2',
    icon: '🔪',
    title: 'Slice',
    text: 'Any slicer, any FDM printer, PLA works great. Try 0.2 mm layers and ~15 % infill — no supports needed, Qutie prints as one piece.',
  },
  {
    n: '3',
    icon: '✨',
    title: 'Print & enjoy',
    text: 'A few hours later you’re holding a quantum computer. Sort of. Print one for your desk — and a few more to give away.',
  },
];

const family = [
  {
    href: 'https://rasqberry.org',
    icon: '🍓',
    title: 'RasQberry Two',
    text: 'The flagship: 3D-print a model of IBM Quantum System Two with a real Raspberry Pi inside, running Qiskit demos.',
    meta: 'rasqberry.org ↗',
  },
  {
    href: 'https://quantego.org',
    icon: '🧱',
    title: 'Quantego',
    text: 'Quantum computers built from LEGO bricks — three models with full part lists and instructions.',
    meta: 'quantego.org ↗',
  },
  {
    href: 'https://fun-with-quantum.org',
    icon: '🎲',
    title: 'Fun with Quantum',
    text: 'The family portal: quantum games you play in the browser, things to build, and hands-on ways to learn.',
    meta: 'fun-with-quantum.org ↗',
  },
];
---

<Base
  title="Qutie — a quantum computer that fits in your palm"
  description="Cute, palm-sized models of quantum computers, 3D-printable in one piece. No electronics, no assembly. The mini RasQberry — open source, from the Fun with Quantum family."
  ogImage={heroPhoto?.src.src}
>
  {firstModel ? (
    <section class="stage-section" id="models">
      <div class="wrap">
        <div class="kicker">The pocket-sized quantum computer</div>
        <div class="stage-grid">
          <div class="stage">
            <canvas id="stage-canvas" aria-label={`Interactive 3D preview of ${firstModel.name}`}></canvas>
            <div class="stage-hint">drag to spin · it also spins on its own</div>
          </div>
          <aside class="stage-panel">
            <h2 class="model-name" id="model-name">{firstModel.name}</h2>
            <p class="meta" id="model-meta">STL · {firstModel.size} · prints in one piece</p>
            {heroPhoto && (
              <figure class="panel-photo">
                <Image
                  src={heroPhoto.src}
                  alt={`${heroPhoto.caption} — 3D-printed and palm-sized`}
                  widths={[360, 720]}
                  sizes="(max-width: 820px) 90vw, 360px"
                />
              </figure>
            )}
            <a class="btn primary sm" id="model-download" href={firstModel.url} download>⬇ Download STL</a>
            <div class="chips" role="group" aria-label="Choose a model">
              {models.map((m, i) => (
                <button
                  class="chip"
                  aria-pressed={i === 0 ? 'true' : 'false'}
                  data-src={m.url}
                  data-name={m.name}
                  data-size={m.size}
                  data-color={m.look.color}
                  data-metalness={m.look.metalness}
                  data-roughness={m.look.roughness}
                  data-rotate={m.look.rotate}
                >
                  {m.name.replace(/^Qutie\s+/i, '')}
                </button>
              ))}
            </div>
            <p class="stage-note">All models open source (Apache-2.0 or CC BY-SA 4.0) — remix away.</p>
          </aside>
        </div>
      </div>
    </section>
  ) : (
    <section class="stage-section" id="models">
      <div class="wrap">
        <div class="kicker">The pocket-sized quantum computer</div>
        <div class="card soon-card">
          <span class="icon">🚧</span>
          <h3>The first STL files land here very soon</h3>
          <p>
            The models are printed, photographed, and being polished for release. Watch the
            repository on GitHub and you’ll be notified the moment they drop — with an interactive
            3D showroom right on this page.
          </p>
          <a class="btn ghost" href="https://github.com/JanLahmann/Qutie" target="_blank" rel="noopener">👀 Watch on GitHub</a>
        </div>
      </div>
    </section>
  )}

  <section class="section intro" id="why">
    <div class="wrap">
      <h1>A quantum computer that fits in your palm.</h1>
      <p class="lead">
        Qutie is the mini RasQberry: cute, palm-sized models of quantum computers that 3D-print in
        one piece on any home printer. No electronics, no assembly, no excuses — print one, put it
        on your desk, give one away.
      </p>
      <div class="grid cols-3">
        {why.map((w) => (
          <div class="card">
            <span class="icon">{w.icon}</span>
            <h3>{w.title}</h3>
            <p>{w.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {gallery.length > 0 && (
    <section class="section" id="gallery">
      <div class="wrap">
        <div class="kicker">Gallery</div>
        <h2>Quties in the wild</h2>
        <div class="grid cols-3 gallery-grid">
          {gallery.map((g) => (
            <figure>
              <Image src={g.src} alt={g.caption} widths={[420, 800]} sizes="(max-width: 820px) 90vw, 340px" />
              <figcaption>{g.caption}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section" id="print">
    <div class="wrap">
      <div class="kicker">Print it</div>
      <h2>From STL to desk in three steps</h2>
      <p class="lead">
        If your printer can print a benchy, it can print a Qutie. No special hardware, no exotic
        filament, no post-processing.
      </p>
      <div class="grid cols-3">
        {steps.map((s) => (
          <div class="card step">
            <span class="stepno">{s.n}</span>
            <span class="icon">{s.icon}</span>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="family">
    <div class="wrap">
      <div class="kicker">The family</div>
      <h2>Qutie’s big siblings</h2>
      <p class="lead">
        Qutie is the smallest member of the Fun with Quantum family — open-source quantum outreach
        projects built by Jan-R. Lahmann and the RasQberry community, tested on real audiences from
        school classes to IEEE conferences.
      </p>
      <div class="grid cols-3">
        {family.map((f) => (
          <a class="card" href={f.href} target="_blank" rel="noopener">
            <span class="icon">{f.icon}</span>
            <h3>{f.title}</h3>
            <p>{f.text}</p>
            <span class="meta">{f.meta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="tagline-strip">
    <b>GOD DOES PLAY DICE.</b> COME PLAY, BUILD, LEARN.
  </div>

  <div class="trust wrap">
    <span>100% open source</span>
    <span>prints in one piece</span>
    <span>no electronics, no assembly</span>
    <span>no accounts, no cookies</span>
    <span>from the makers of RasQberry</span>
  </div>
</Base>

<style>
  /* ---------- showroom stage ---------- */
  .stage-section { padding: 40px 0 8px; }
  .stage-grid {
    display: grid; grid-template-columns: 1.6fr 1fr; gap: 40px; align-items: center;
    margin-top: 6px;
  }
  @media (max-width: 820px) { .stage-grid { grid-template-columns: 1fr; gap: 20px; } }

  .stage { position: relative; }
  #stage-canvas {
    width: 100%; aspect-ratio: 16 / 10; display: block;
    border-radius: 18px;
    background:
      radial-gradient(ellipse at 50% 45%, color-mix(in srgb, var(--cyan) 9%, var(--card)), var(--card) 75%);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    touch-action: pan-y; cursor: grab;
  }
  .stage-hint {
    position: absolute; left: 0; right: 0; bottom: 12px;
    text-align: center; pointer-events: none;
    font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.06em;
    color: var(--muted);
  }

  .stage-panel { display: flex; flex-direction: column; gap: 12px; align-items: flex-start; }
  .panel-photo { width: 100%; }
  .panel-photo img {
    width: 100%; height: auto; border-radius: 12px; box-shadow: var(--shadow);
  }
  .btn.sm { padding: 9px 16px; font-size: 0.88rem; }
  .model-name { font-size: 1.9rem; }
  .stage-panel .meta {
    font-family: var(--mono); font-size: 0.75rem; letter-spacing: 0.06em; color: var(--muted);
  }
  .chips { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 6px; }
  .chip {
    font-family: var(--mono); font-size: 0.78rem; letter-spacing: 0.05em;
    padding: 7px 14px; border-radius: 20px;
    border: 1.5px solid var(--line); background: var(--card); color: var(--muted);
    cursor: pointer;
  }
  .chip:hover { border-color: var(--cyan); color: var(--cyan); }
  .chip[aria-pressed='true'] { border-color: var(--magenta); color: var(--magenta); font-weight: 700; }
  .stage-note { font-size: 0.8rem; color: var(--muted); }

  /* ---------- intro ---------- */
  .intro h1 { font-size: 2.3rem; margin-bottom: 12px; max-width: 700px; }
  @media (max-width: 820px) { .intro h1 { font-size: 1.8rem; } }

  .card.step { position: relative; }
  .stepno {
    position: absolute; top: 18px; right: 22px;
    font-family: var(--mono); font-size: 2rem; font-weight: 700;
    background: var(--grad); -webkit-background-clip: text; background-clip: text;
    color: transparent; opacity: 0.55; line-height: 1;
  }

  .soon-card { max-width: 560px; margin-top: 16px; }
  .soon-card .btn { align-self: flex-start; margin-top: 6px; }

  /* ---------- gallery ---------- */
  .gallery-grid { align-items: start; margin-top: 24px; }
  .gallery-grid img {
    width: 100%; height: auto;
    border-radius: 14px; box-shadow: var(--shadow);
  }
  .gallery-grid figcaption {
    margin-top: 8px; font-size: 0.8rem; color: var(--muted); text-align: center;
  }
</style>

<script>
  // Showroom stage — one three.js viewer, models swapped via the chips.
  const canvas = document.querySelector<HTMLCanvasElement>('#stage-canvas');

  async function initStage(canvas: HTMLCanvasElement) {
    const [THREE, { STLLoader }, { OrbitControls }] = await Promise.all([
      import('three'),
      import('three/addons/loaders/STLLoader.js'),
      import('three/addons/controls/OrbitControls.js'),
    ]);

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(40, 16 / 10, 0.1, 2000);

    scene.add(new THREE.HemisphereLight(0xffffff, 0x50546a, 1.8));
    const key = new THREE.DirectionalLight(0xffffff, 2.0);
    key.position.set(1, 2, 1.5);
    scene.add(key);
    const rim = new THREE.DirectionalLight(0xffffff, 1.1);
    rim.position.set(-1.5, 0.8, -1.5);
    scene.add(rim);
    const fill = new THREE.DirectionalLight(0x0f62fe, 0.3); // IBM blue accent
    fill.position.set(-1.5, -0.5, 1);
    scene.add(fill);

    const controls = new OrbitControls(camera, canvas);
    controls.enablePan = false;
    controls.enableZoom = false;
    controls.autoRotate = true;
    controls.autoRotateSpeed = 2.2;
    controls.enableDamping = true;

    const loader = new STLLoader();
    let mesh: InstanceType<typeof THREE.Mesh> | null = null;
    let generation = 0;

    async function show(data: DOMStringMap) {
      const gen = ++generation;
      const geometry = await loader.loadAsync(data.src!);
      if (gen !== generation) return; // a newer chip click won the race
      geometry.center();
      geometry.computeBoundingSphere();
      const radius = geometry.boundingSphere?.radius ?? 1;

      if (mesh) {
        scene.remove(mesh);
        mesh.geometry.dispose();
        (mesh.material as InstanceType<typeof THREE.Material>).dispose();
      }
      mesh = new THREE.Mesh(
        geometry,
        new THREE.MeshStandardMaterial({
          color: new THREE.Color(data.color || '#2fa9cc'),
          roughness: Number(data.roughness ?? 0.55),
          metalness: Number(data.metalness ?? 0.05),
        })
      );
      mesh.rotation.x = -Math.PI / 2; // STLs are usually Z-up; three.js is Y-up
      mesh.rotation.z = (Number(data.rotate ?? 0) * Math.PI) / 180; // per-model start angle
      scene.add(mesh);
      camera.position.set(0, radius * 0.9, radius * 2.6);
      controls.target.set(0, 0, 0);
    }

    const resize = () => {
      const { clientWidth, clientHeight } = canvas;
      if (clientWidth === 0) return;
      renderer.setSize(clientWidth, clientHeight, false);
      camera.aspect = clientWidth / clientHeight;
      camera.updateProjectionMatrix();
    };
    resize();
    new ResizeObserver(resize).observe(canvas);

    renderer.setAnimationLoop(() => {
      controls.update();
      renderer.render(scene, camera);
    });

    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip'));
    const nameEl = document.getElementById('model-name')!;
    const metaEl = document.getElementById('model-meta')!;
    const downloadEl = document.getElementById('model-download') as HTMLAnchorElement;

    chips.forEach((chip) =>
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.setAttribute('aria-pressed', String(c === chip)));
        nameEl.textContent = chip.dataset.name!;
        metaEl.textContent = `STL · ${chip.dataset.size} · prints in one piece`;
        downloadEl.href = chip.dataset.src!;
        canvas!.setAttribute('aria-label', `Interactive 3D preview of ${chip.dataset.name}`);
        show(chip.dataset);
      })
    );

    if (chips[0]) await show(chips[0].dataset);
  }

  if (canvas) initStage(canvas);
</script>
